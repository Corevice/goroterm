default_platform(:ios)

platform :android do
  desc "Upload AAB to Google Play Internal Testing (draft)"
  lane :deploy do
    upload_to_play_store(
      track: "internal",
      release_status: "draft",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      # internal track はメタデータ反映が遅延しがちなので
      # production lane でだけメタデータを送る
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end

  desc "Upload AAB + localized store listings to Google Play Production (100% rollout)"
  lane :deploy_production do
    upload_to_play_store(
      track: "production",
      release_status: "completed",
      aab: "build/app/outputs/bundle/release/app-release.aab",
      # fastlane/metadata/android/{en-US,ja-JP,id}/ から
      # title / short_description / full_description / changelogs を反映
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      # スクリーンショットと feature graphic は別途整備するまでスキップ
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end

platform :ios do
  def asc_api_key
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY_P8"],
      is_key_content_base64: false,
      in_house: false,
    )
  end

  desc "Upload IPA to TestFlight"
  lane :deploy do
    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true,
      ipa: "build/ios/ipa/GoroTerm.ipa",
    )
  end

  # App Store Connect のメタデータ (説明文 / キーワード / プロモ文 / URL) のみ
  # を更新。バイナリ・スクリーンショットは触らない。本番審査前のメタ修正に使う。
  desc "Upload App Store metadata (no binary, no screenshots)"
  lane :metadata do
    deliver(
      api_key: asc_api_key,
      metadata_path: "./fastlane/metadata/ios",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,                 # HTML プレビューをスキップ
      precheck_include_in_app_purchases: false,
    )
  end

  # App Store 審査提出。メタデータ更新 + 最新 TestFlight ビルドを使って submit。
  # スクリーンショットは別途 App Store Connect 側で揃えておくこと。
  desc "Submit latest TestFlight build to App Store review"
  lane :submit_review do
    deliver(
      api_key: asc_api_key,
      metadata_path: "./fastlane/metadata/ios",
      skip_binary_upload: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,    # 承認後の公開タイミングは手動
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        # SSH の標準暗号 (AES/RSA/ECDSA) のみ → exempt 扱い
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        export_compliance_encryption_updated: false,
        export_compliance_app_type: nil,
        export_compliance_contains_third_party_cryptography: false,
        export_compliance_contains_proprietary_cryptography: false,
        export_compliance_available_on_french_store: true,
        # 第三者コンテンツ・広告識別子
        content_rights_contains_third_party_content: false,
        add_id_info_uses_idfa: false,
      },
    )
  end
end

platform :mac do
  # Developer ID 配信用パッケージング。
  # 前提: `flutter build macos --release` 済み + キーチェーンに
  #       "Developer ID Application: ..." 証明書が入っていること
  #       (Xcode 側の DEVELOPMENT_TEAM=58M86RXHRB + ENABLE_HARDENED_RUNTIME=YES で
  #        flutter build が Developer ID 署名付きの .app を出力する)
  # 出力: build/macos/release/Goroterm-<version>.dmg (公証済み・stapled)
  desc "Create signed/notarized DMG for Developer ID distribution"
  lane :deploy do
    app_path = "build/macos/Build/Products/Release/Goroterm.app"
    UI.user_error!("App not found: #{app_path}. Run `flutter build macos --release` first.") \
      unless File.exist?("../#{app_path}")

    plist = "../#{app_path}/Contents/Info.plist"
    version = sh("/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' '#{plist}'").strip

    out_dir = "build/macos/release"
    sh("mkdir -p ../#{out_dir}")
    dmg_path = "#{out_dir}/Goroterm-#{version}.dmg"
    sh("rm -f ../#{dmg_path}")

    # DMG 中身を整える: .app + /Applications シンボリックリンクで
    # 「Applications フォルダへドラッグ」UI にする。
    stage = "../build/macos/dmg-stage"
    sh("rm -rf '#{stage}' && mkdir -p '#{stage}'")
    sh("cp -R '../#{app_path}' '#{stage}/Goroterm.app'")
    sh("ln -s /Applications '#{stage}/Applications'")

    # DMG 作成 (UDZO = 圧縮)。
    sh("hdiutil create -volname 'Goroterm' -srcfolder '#{stage}' -ov -format UDZO '../#{dmg_path}'")
    sh("rm -rf '#{stage}'")

    # DMG 自身も Developer ID で署名 (Gatekeeper 検証を高速化)
    signing_identity = ENV["MACOS_SIGNING_IDENTITY"] || "Developer ID Application"
    sh("codesign --force --sign '#{signing_identity}' --timestamp '../#{dmg_path}'")

    # 公証 + staple は notarytool を直接呼ぶ。
    # fastlane の `notarize` アクションは notarytool 出力 (タイムスタンプ付き) を
    # JSON.parse しようとして失敗するため使わない。
    key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"]
    key_content = ENV["APP_STORE_CONNECT_API_KEY_P8"]
    UI.user_error!("Missing APP_STORE_CONNECT_* env vars") \
      if key_id.nil? || issuer_id.nil? || key_content.nil? || key_content.empty?

    require "tempfile"
    key_file = Tempfile.new(["AuthKey_#{key_id}", ".p8"])
    key_file.write(key_content)
    key_file.close

    UI.message("Submitting #{dmg_path} to notarytool…")
    sh("xcrun notarytool submit '../#{dmg_path}' " \
       "--key '#{key_file.path}' --key-id '#{key_id}' --issuer '#{issuer_id}' " \
       "--wait --output-format json")

    UI.message("Stapling notarization ticket…")
    sh("xcrun stapler staple '../#{dmg_path}'")

    sh("xcrun stapler validate '../#{dmg_path}'")
    UI.success("Notarized DMG: #{dmg_path}")
  ensure
    key_file&.unlink
  end
end
